#!/bin/bash
#MISE description="Generate workflow files from workflows.yaml"
#USAGE flag "--check" default=#false help="Check mode: fail if generated files differ from committed"
set -euo pipefail

# Determine target directory (caller's directory when using shimmer alias)
TARGET_DIR="${PROJECT_DIR:-${SHIMMER_CALLER_PWD:-${CALLER_PWD:-.}}}"
cd "$TARGET_DIR"

# Validate workflows.yaml against schema
if [[ -f workflows.yaml ]]; then
  echo "Validating workflows.yaml..."
  check-jsonschema --schemafile "$MISE_PROJECT_ROOT/workflows.schema.json" workflows.yaml
fi

# Use local template if exists, otherwise use shimmer's
if [[ -f ".github/templates/agent-scheduled.yml" ]]; then
  SCHEDULED_TEMPLATE=".github/templates/agent-scheduled.yml"
else
  SCHEDULED_TEMPLATE="$MISE_PROJECT_ROOT/.github/templates/agent-scheduled.yml"
fi

CHECK_MODE="$usage_check"
OUTPUT_ROOT=".github"

# Use temp dir in check mode
if [[ "$CHECK_MODE" == "true" ]]; then
  OUTPUT_ROOT=$(mktemp -d)
  trap 'rm -rf "$OUTPUT_ROOT"' EXIT
fi

OUTPUT_DIR="$OUTPUT_ROOT/workflows"
SCRIPT_DIR="$OUTPUT_ROOT/scripts"

mkdir -p "$OUTPUT_DIR"

GENERATED_WORKFLOW_NAMES=$'agent-run\nagent-mention\n'
EXPECTED_GENERATED_WORKFLOW_FILES=$'agent-run.yml\n'

agent_secret_prefix() {
  printf '%s' "$1" | tr '[:lower:]-' '[:upper:]_'
}

agent_output_name() {
  printf '%s' "$1" | tr '-' '_'
}

validate_agent_name() {
  local agent="$1"

  if [[ ! "$agent" =~ ^[a-z][a-z0-9]*(-[a-z0-9]+)*$ ]]; then
    echo "Error: invalid agent name '$agent' from agent:list; expected ^[a-z][a-z0-9]*(-[a-z0-9]+)*$" >&2
    exit 1
  fi

  case "$agent" in
    agent-run|agent-mention)
      echo "Error: invalid agent name '$agent' from agent:list; name is reserved by generated workflows" >&2
      exit 1
      ;;
  esac
}

validate_workflow_name() {
  local name="$1"

  if [[ ! "$name" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
    echo "Error: invalid workflow name '$name' from workflows.yaml; expected ^[a-z0-9][a-z0-9-]*$" >&2
    exit 1
  fi
}

workflow_name_in_use() {
  local needle="$1"
  local workflow_name
  while IFS= read -r workflow_name; do
    [[ -z "$workflow_name" ]] && continue
    [[ "$workflow_name" == "$needle" ]] && return 0
  done <<< "$GENERATED_WORKFLOW_NAMES"
  return 1
}

reserve_workflow_name() {
  local name="$1"
  local source="$2"

  if workflow_name_in_use "$name"; then
    echo "Error: generated workflow name '$name' from $source conflicts with another generated workflow" >&2
    exit 1
  fi

  GENERATED_WORKFLOW_NAMES+="${name}"$'\n'
}

expect_generated_workflow_file() {
  local filename="$1"
  EXPECTED_GENERATED_WORKFLOW_FILES+="${filename}"$'\n'
}

generated_workflow_file_expected() {
  local needle="$1"
  local filename
  while IFS= read -r filename; do
    [[ -z "$filename" ]] && continue
    [[ "$filename" == "$needle" ]] && return 0
  done <<< "$EXPECTED_GENERATED_WORKFLOW_FILES"
  return 1
}

is_generated_workflow_file() {
  local file="$1"
  grep -q '^# ⚠️  AUTO-GENERATED' "$file" 2>/dev/null
}

handle_stale_generated_workflows() {
  local workflow_dir="$1"
  local mode="$2"
  local file filename

  [[ -d "$workflow_dir" ]] || return 0

  while IFS= read -r -d '' file; do
    filename=$(basename "$file")
    if generated_workflow_file_expected "$filename"; then
      continue
    fi
    if ! is_generated_workflow_file "$file"; then
      continue
    fi

    if [[ "$mode" == "check" ]]; then
      echo "Unexpected: .github/workflows/$filename (stale generated workflow; regenerate with current workflows.yaml/agent:list)"
      DIFF_FOUND=true
    else
      rm -f "$file"
      echo "Removed stale generated workflow: $filename"
    fi
  done < <(find "$workflow_dir" -maxdepth 1 -type f \( -name '*.yml' -o -name '*.yaml' \) -print0)
}

agent_in_roster() {
  local needle="$1"
  local agent
  while IFS= read -r agent; do
    [[ -z "$agent" ]] && continue
    [[ "$agent" == "$needle" ]] && return 0
  done <<< "$AGENTS"
  return 1
}

yaml_scalar_from_file() {
  local value_file="$1"

  python3 - "$value_file" <<'PY'
import json
import sys
from pathlib import Path

print(json.dumps(Path(sys.argv[1]).read_text(encoding="utf-8")))
PY
}

csv_from_lines() {
  awk 'NF { printf "%s%s", sep, $0; sep="," } END { print "" }'
}

agent_metadata_is_valid() {
  jq -e 'type == "array" and all(.[]; type == "object" and (.name | type == "string"))' >/dev/null 2>&1
}

agent_names_from_metadata() {
  jq -r '.[].name'
}

agent_login_map_from_metadata() {
  jq -e -c '
    if any(.[]; ((.github_login // "") | length) == 0) then
      error(
        "agent:list JSON missing github_login for: "
        + ([.[] | select(((.github_login // "") | length) == 0) | .name] | join(", "))
      )
    else
      reduce .[] as $agent ({}; .[$agent.name] = $agent.github_login)
    end
  '
}

replace_file_token_from_file() {
  local target_file="$1"
  local token="$2"
  local replacement_file="$3"

  python3 - "$target_file" "$token" "$replacement_file" <<'PY'
from pathlib import Path
import sys

target = Path(sys.argv[1])
token = sys.argv[2]
replacement = Path(sys.argv[3]).read_text(encoding="utf-8")
text = target.read_text(encoding="utf-8")
target.write_text(text.replace(token, replacement), encoding="utf-8")
PY
}

replace_schedule_placeholder() {
  local target_file="$1"
  local schedule_file="$2"
  local tmp_file

  tmp_file=$(mktemp)
  awk -v schedule_file="$schedule_file" '
    /__SCHEDULE_ENTRIES__/ {
      while ((getline line < schedule_file) > 0) print line
      close(schedule_file)
      next
    }
    { print }
  ' "$target_file" > "$tmp_file"
  mv "$tmp_file" "$target_file"
}

generate_agent_workflow() {
  local agent="$1"
  local agent_upper
  agent_upper=$(agent_secret_prefix "$agent")

  cat > "$OUTPUT_DIR/${agent}.yml" <<WORKFLOW_EOF
# ⚠️  AUTO-GENERATED — do not edit this file directly.
# Source: shimmer workflows generate
# Regenerate: shimmer workflows generate

name: '${agent}'

on:
  workflow_dispatch:
    inputs:
      message:
        description: 'Message for the agent'
        required: true
        type: string
      model:
        description: 'Provider-qualified model to use (e.g., openai-codex/gpt-5.5)'
        required: true
        type: string
  workflow_call:
    inputs:
      message:
        description: 'Message for the agent'
        required: true
        type: string
      model:
        description: 'Provider-qualified model to use (e.g., openai-codex/gpt-5.5)'
        required: true
        type: string
    secrets:
      ANTHROPIC_API_KEY:
        required: false
      HF_TOKEN:
        required: false
      PI_AUTH_JSON:
        required: false
      ${agent_upper}_GITHUB_PAT:
        required: true
      ${agent_upper}_GPG_PRIVATE_KEY:
        required: true
      ${agent_upper}_EMAIL_PASSWORD:
        required: true
      ${agent_upper}_GITHUB_PASSWORD:
        required: false
      ${agent_upper}_B2_ENDPOINT:
        required: false
      ${agent_upper}_B2_KEY_ID:
        required: false
      ${agent_upper}_B2_APPLICATION_KEY:
        required: false
      ${agent_upper}_B2_BUCKET:
        required: false

jobs:
  run:
    uses: ./.github/workflows/agent-run.yml
    with:
      agent: '${agent}'
      message: \${{ inputs.message }}
      model: \${{ inputs.model }}
    secrets:
      ANTHROPIC_API_KEY: \${{ secrets.ANTHROPIC_API_KEY }}
      HF_TOKEN: \${{ secrets.HF_TOKEN }}
      PI_AUTH_JSON: \${{ secrets.PI_AUTH_JSON }}
      AGENT_GITHUB_PAT: \${{ secrets.${agent_upper}_GITHUB_PAT }}
      AGENT_GPG_PRIVATE_KEY: \${{ secrets.${agent_upper}_GPG_PRIVATE_KEY }}
      AGENT_EMAIL_PASSWORD: \${{ secrets.${agent_upper}_EMAIL_PASSWORD }}
      AGENT_GITHUB_PASSWORD: \${{ secrets.${agent_upper}_GITHUB_PASSWORD }}
      AGENT_B2_ENDPOINT: \${{ secrets.${agent_upper}_B2_ENDPOINT }}
      AGENT_B2_KEY_ID: \${{ secrets.${agent_upper}_B2_KEY_ID }}
      AGENT_B2_APPLICATION_KEY: \${{ secrets.${agent_upper}_B2_APPLICATION_KEY }}
      AGENT_B2_BUCKET: \${{ secrets.${agent_upper}_B2_BUCKET }}
WORKFLOW_EOF
}

generate_scheduled_workflow() {
  local index="$1"
  local name agent message model schedule_count schedule_entries schedule_tmp name_tmp message_tmp model_tmp output_file cron
  local name_yaml message_yaml model_yaml

  name=$(yq -r ".workflows[$index].name" workflows.yaml)
  agent=$(yq -r ".workflows[$index].agent" workflows.yaml)
  message=$(yq -r ".workflows[$index].message" workflows.yaml)
  model=$(yq -r ".workflows[$index].model" workflows.yaml)
  validate_workflow_name "$name"
  reserve_workflow_name "$name" "workflow '$name'"
  if [[ -z "$model" || "$model" == "null" ]]; then
    echo "Error: workflow '$name' is missing required model" >&2
    exit 1
  fi
  validate_agent_name "$agent"
  if ! agent_in_roster "$agent"; then
    echo "Error: workflow '$name' references agent '$agent', but agent:list did not report that agent" >&2
    exit 1
  fi

  schedule_entries=""
  schedule_count=$(yq -r ".workflows[$index].schedule | length" workflows.yaml)
  for j in $(seq 0 $((schedule_count - 1))); do
    cron=$(yq -r ".workflows[$index].schedule[$j]" workflows.yaml)
    schedule_entries+="    - cron: '${cron}'"$'\n'
  done

  expect_generated_workflow_file "${name}.yml"
  output_file="$OUTPUT_DIR/${name}.yml"
  export AGENT="$agent"

  # shellcheck disable=SC2016  # envsubst's allow-list argument: literal ${VAR} tokens are the contract.
  envsubst '${AGENT}' < "$SCHEDULED_TEMPLATE" > "$output_file"

  name_tmp=$(mktemp)
  printf '%s' "$name" > "$name_tmp"
  name_yaml=$(yaml_scalar_from_file "$name_tmp")
  printf '%s' "$name_yaml" > "$name_tmp"
  # shellcheck disable=SC2016  # Replace the literal ${NAME} placeholder after envsubst.
  replace_file_token_from_file "$output_file" '${NAME}' "$name_tmp"
  rm "$name_tmp"

  message_tmp=$(mktemp)
  printf '%s' "$message" > "$message_tmp"
  message_yaml=$(yaml_scalar_from_file "$message_tmp")
  printf '%s' "$message_yaml" > "$message_tmp"
  # shellcheck disable=SC2016  # Replace the literal ${MESSAGE} placeholder after envsubst.
  replace_file_token_from_file "$output_file" '${MESSAGE}' "$message_tmp"
  rm "$message_tmp"

  model_tmp=$(mktemp)
  printf '%s' "$model" > "$model_tmp"
  model_yaml=$(yaml_scalar_from_file "$model_tmp")
  printf '%s' "$model_yaml" > "$model_tmp"
  # shellcheck disable=SC2016  # Replace the literal ${MODEL} placeholder after envsubst.
  replace_file_token_from_file "$output_file" '${MODEL}' "$model_tmp"
  rm "$model_tmp"

  schedule_tmp=$(mktemp)
  printf '%s' "$schedule_entries" > "$schedule_tmp"
  replace_schedule_placeholder "$output_file" "$schedule_tmp"
  rm "$schedule_tmp"
}

generate_mention_workflow() {
  local agents="$1"
  local roster_csv="$2"
  local login_map_json="$3"
  local model="$4"
  local allowed_associations="$5"
  local output_file="$OUTPUT_DIR/agent-mention.yml"
  local model_tmp model_yaml login_map_tmp login_map_yaml

  expect_generated_workflow_file "agent-mention.yml"

  model_tmp=$(mktemp)
  printf '%s' "$model" > "$model_tmp"
  model_yaml=$(yaml_scalar_from_file "$model_tmp")
  rm "$model_tmp"

  login_map_tmp=$(mktemp)
  printf '%s' "$login_map_json" > "$login_map_tmp"
  login_map_yaml=$(yaml_scalar_from_file "$login_map_tmp")
  rm "$login_map_tmp"

  mkdir -p "$SCRIPT_DIR"
  rm -f "$SCRIPT_DIR/agent-mention-detect.nu"
  cp "$MISE_PROJECT_ROOT/.github/templates/agent-mention-detect.py" "$SCRIPT_DIR/agent-mention-detect.py"

  cat > "$output_file" <<WORKFLOW_EOF
# ⚠️  AUTO-GENERATED — do not edit this file directly.
# Source: shimmer workflows generate + workflows.yaml mention_wakes
# Regenerate: shimmer workflows generate

name: Agent Mention

on:
  issue_comment:
    types: [created]

permissions:
  contents: read
  issues: read
  pull-requests: read

jobs:
  detect:
    name: Detect agent mentions
    runs-on: ubuntu-latest
    outputs:
      should_wake: \${{ steps.detect.outputs.should_wake }}
      reason: \${{ steps.detect.outputs.reason }}
      matched_agents: \${{ steps.detect.outputs.matched_agents }}
WORKFLOW_EOF

  while IFS= read -r agent; do
    [[ -z "$agent" ]] && continue
    local output_name
    output_name=$(agent_output_name "$agent")
    cat >> "$output_file" <<WORKFLOW_EOF
      agent_${output_name}: \${{ steps.detect.outputs.agent_${output_name} }}
WORKFLOW_EOF
  done <<< "$agents"

  cat >> "$output_file" <<WORKFLOW_EOF
      message: \${{ steps.detect.outputs.message }}
    steps:
      - name: Checkout repository
        uses: actions/checkout@v6

      - name: Detect mentions
        id: detect
        env:
          AGENT_ROSTER: ${roster_csv}
          AGENT_GITHUB_LOGINS: ${login_map_yaml}
          # Team fanout stays disabled until fanout limits/jitter are designed explicitly.
          TEAM_ALIASES: ""
          ALLOWED_ASSOCIATIONS: ${allowed_associations}
          GITHUB_TOKEN: \${{ github.token }}
        run: python3 .github/scripts/agent-mention-detect.py

      - name: Mention detection summary
        run: |
          {
            echo "### Agent mention"
            echo ""
            echo "- should_wake: \${{ steps.detect.outputs.should_wake }}"
            echo "- reason: \${{ steps.detect.outputs.reason }}"
            echo "- matched_agents: \${{ steps.detect.outputs.matched_agents }}"
          } >> "\$GITHUB_STEP_SUMMARY"
WORKFLOW_EOF

  while IFS= read -r agent; do
    [[ -z "$agent" ]] && continue
    local output_name
    output_name=$(agent_output_name "$agent")
    cat >> "$output_file" <<WORKFLOW_EOF

  wake-${agent}:
    name: Wake ${agent}
    needs: detect
    if: \${{ needs.detect.outputs.agent_${output_name} == 'true' }}
    concurrency:
      # At most one running and one pending mention wake per thread/agent.
      # A newer pending wake replaces an older pending one; running sessions
      # are not canceled.
      group: agent-mention-${agent}-\${{ github.event.issue.number }}
      cancel-in-progress: false
    uses: ./.github/workflows/${agent}.yml
    with:
      message: \${{ needs.detect.outputs.message }}
      model: ${model_yaml}
    secrets: inherit
WORKFLOW_EOF
  done <<< "$agents"
}

compare_generated_file() {
  local generated="$1"
  local committed="$2"

  if [[ ! -f "$committed" ]]; then
    echo "Missing: $committed"
    DIFF_FOUND=true
  elif ! diff -q "$generated" "$committed" > /dev/null 2>&1; then
    echo "Differs: $committed"
    # diff returns 1 when files differ (the whole point here); accept that, reject other exits.
    diff "$generated" "$committed" || [ $? -eq 1 ]
    DIFF_FOUND=true
  fi
}

# Copy base workflow templates from shimmer
echo "Copying base templates from shimmer..."
cp "$MISE_PROJECT_ROOT/.github/templates/agent-run.yml" "$OUTPUT_DIR/agent-run.yml"
echo "Generated: agent-run.yml"

# Generate per-agent workflow files from agent:list
AGENT_METADATA_JSON=""
if AGENT_METADATA_CANDIDATE=$(mise run -q agent:list -- --ci --json 2>/dev/null) && printf '%s' "$AGENT_METADATA_CANDIDATE" | agent_metadata_is_valid; then
  AGENT_METADATA_JSON="$AGENT_METADATA_CANDIDATE"
  AGENTS=$(printf '%s' "$AGENT_METADATA_JSON" | agent_names_from_metadata)
else
  AGENTS=$(mise run -q agent:list -- --ci 2>/dev/null) || AGENTS=""
fi

if [[ -n "$AGENTS" ]]; then
  echo "Discovered agents: $(echo "$AGENTS" | tr '\n' ' ')"

  AGENT_COUNT=0
  while IFS= read -r agent; do
    [[ -z "$agent" ]] && continue
    validate_agent_name "$agent"
    reserve_workflow_name "$agent" "agent:list entry '$agent'"
    expect_generated_workflow_file "${agent}.yml"
    generate_agent_workflow "$agent"
    echo "Generated: ${agent}.yml"
    AGENT_COUNT=$((AGENT_COUNT + 1))
  done <<< "$AGENTS"

  echo "Generated $AGENT_COUNT agent workflow(s)"
else
  echo "ERROR: No agent:list task found." >&2
  echo "       Agent homes must implement an agent:list task that outputs one agent name per line." >&2
  exit 1
fi

WORKFLOW_COUNT=0
MENTION_ENABLED="false"
MENTION_MODEL=""
MENTION_ALLOWED="OWNER,MEMBER"

if [[ -f workflows.yaml ]]; then
  WORKFLOW_COUNT=$(yq -r '.workflows // [] | length' workflows.yaml 2>/dev/null || echo "0")
  MENTION_ENABLED=$(yq -r '.mention_wakes.enabled // false' workflows.yaml 2>/dev/null || echo "false")
  if [[ "$MENTION_ENABLED" == "true" ]]; then
    MENTION_MODEL=$(yq -r '.mention_wakes.model // ""' workflows.yaml)
    if [[ -z "$MENTION_MODEL" || "$MENTION_MODEL" == "null" ]]; then
      echo "Error: mention_wakes.model is required when mention_wakes.enabled is true" >&2
      exit 1
    fi
    MENTION_ALLOWED=$(yq -r '.mention_wakes.allowed_associations // ["OWNER", "MEMBER"] | join(",")' workflows.yaml)
  fi
fi

# Generate scheduled workflows (if workflows.yaml exists and has workflows)
if [[ "$WORKFLOW_COUNT" -gt 0 ]]; then
  for i in $(seq 0 $((WORKFLOW_COUNT - 1))); do
    NAME=$(yq -r ".workflows[$i].name" workflows.yaml)
    generate_scheduled_workflow "$i"
    echo "Generated: ${NAME}.yml"
  done
fi

if [[ "$MENTION_ENABLED" == "true" ]]; then
  if [[ -z "$AGENT_METADATA_JSON" ]]; then
    echo "Error: mention_wakes requires agent:list --ci --json records with github_login for each wakeable agent." >&2
    echo "       The line-oriented agent:list contract is still supported for manual/scheduled workflows only." >&2
    exit 1
  fi
  AGENT_CSV=$(printf '%s\n' "$AGENTS" | csv_from_lines)
  if ! AGENT_LOGIN_MAP=$(printf '%s' "$AGENT_METADATA_JSON" | agent_login_map_from_metadata); then
    echo "Error: mention_wakes requires github_login for every agent in agent:list --ci --json." >&2
    exit 1
  fi
  generate_mention_workflow "$AGENTS" "$AGENT_CSV" "$AGENT_LOGIN_MAP" "$MENTION_MODEL" "$MENTION_ALLOWED"
  echo "Generated: agent-mention.yml"
  echo "Generated: agent-mention-detect.py"
elif [[ "$CHECK_MODE" != "true" ]]; then
  rm -f "$OUTPUT_DIR/agent-mention.yml" "$SCRIPT_DIR/agent-mention-detect.py" "$SCRIPT_DIR/agent-mention-detect.nu"
fi

if [[ "$CHECK_MODE" != "true" ]]; then
  handle_stale_generated_workflows "$OUTPUT_DIR" "apply"
fi

# In check mode, diff against committed files
if [[ "$CHECK_MODE" == "true" ]]; then
  DIFF_FOUND=false

  compare_generated_file "$OUTPUT_DIR/agent-run.yml" ".github/workflows/agent-run.yml"

  while IFS= read -r agent; do
    [[ -z "$agent" ]] && continue
    compare_generated_file "$OUTPUT_DIR/${agent}.yml" ".github/workflows/${agent}.yml"
  done <<< "$AGENTS"

  if [[ "$WORKFLOW_COUNT" -gt 0 ]]; then
    for i in $(seq 0 $((WORKFLOW_COUNT - 1))); do
      NAME=$(yq -r ".workflows[$i].name" workflows.yaml)
      compare_generated_file "$OUTPUT_DIR/${NAME}.yml" ".github/workflows/${NAME}.yml"
    done
  fi

  handle_stale_generated_workflows ".github/workflows" "check"

  if [[ "$MENTION_ENABLED" == "true" ]]; then
    compare_generated_file "$OUTPUT_DIR/agent-mention.yml" ".github/workflows/agent-mention.yml"
    compare_generated_file "$SCRIPT_DIR/agent-mention-detect.py" ".github/scripts/agent-mention-detect.py"
    if [[ -f ".github/scripts/agent-mention-detect.nu" ]]; then
      echo "Unexpected: .github/scripts/agent-mention-detect.nu (legacy Nushell mention detector; regenerate with current shimmer)"
      DIFF_FOUND=true
    fi
  else
    if [[ -f ".github/workflows/agent-mention.yml" ]]; then
      echo "Unexpected: .github/workflows/agent-mention.yml (mention_wakes is not enabled)"
      DIFF_FOUND=true
    fi
    if [[ -f ".github/scripts/agent-mention-detect.py" ]]; then
      echo "Unexpected: .github/scripts/agent-mention-detect.py (mention_wakes is not enabled)"
      DIFF_FOUND=true
    fi
    if [[ -f ".github/scripts/agent-mention-detect.nu" ]]; then
      echo "Unexpected: .github/scripts/agent-mention-detect.nu (mention_wakes is not enabled)"
      DIFF_FOUND=true
    fi
  fi

  if [[ "$DIFF_FOUND" == "true" ]]; then
    echo ""
    echo "Workflow files are out of sync"
    echo "Run 'shimmer workflows:generate' to regenerate"
    exit 1
  fi

  echo ""
  echo "All workflow files are in sync"
fi
