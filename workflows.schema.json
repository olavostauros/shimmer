{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/KnickKnackLabs/shimmer/workflows.schema.json",
  "title": "Workflow Configuration",
  "description": "Defines generated agent workflow triggers",

  "type": "object",
  "properties": {
    "workflows": {
      "type": "array",
      "description": "List of scheduled workflows",
      "items": { "$ref": "#/$defs/workflow" }
    },
    "mention_wakes": { "$ref": "#/$defs/mention_wakes" }
  },

  "$defs": {
    "workflow": {
      "title": "Workflow",
      "description": "A scheduled agent workflow",
      "type": "object",
      "required": ["name", "agent", "schedule", "message", "model"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Workflow name (used for filename: <name>.yml)",
          "pattern": "^[a-z0-9-]+$"
        },
        "agent": {
          "type": "string",
          "description": "Agent to run (e.g., c0da, quick)",
          "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
        },
        "schedule": {
          "type": "array",
          "description": "Cron expressions (e.g., ['0 */4 * * *'] for every 4 hours)",
          "items": {
            "type": "string",
            "pattern": "^[0-9*,/-]+ [0-9*,/-]+ [0-9*,/-]+ [0-9*,/-]+ [0-9*,/-]+$"
          },
          "minItems": 1
        },
        "message": {
          "type": "string",
          "description": "Message/instruction for the agent"
        },
        "model": { "$ref": "#/$defs/provider_qualified_model" }
      }
    },
    "mention_wakes": {
      "title": "Mention wake configuration",
      "description": "Issue-comment mention wake trigger configuration",
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Generate the issue_comment mention wake workflow"
        },
        "model": { "$ref": "#/$defs/provider_qualified_model" },
        "allowed_associations": {
          "type": "array",
          "description": "GitHub comment author associations allowed to wake agents",
          "items": {
            "type": "string",
            "enum": [
              "OWNER",
              "MEMBER",
              "COLLABORATOR",
              "CONTRIBUTOR",
              "FIRST_TIMER",
              "FIRST_TIME_CONTRIBUTOR",
              "MANNEQUIN",
              "NONE"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          },
          "then": { "required": ["model"] }
        }
      ]
    },
    "provider_qualified_model": {
      "type": "string",
      "description": "Provider-qualified model to use (for example: openai-codex/gpt-5.5)",
      "pattern": "^[a-z0-9][a-z0-9._-]*/[A-Za-z0-9][A-Za-z0-9._:/-]*$",
      "examples": [
        "openai-codex/gpt-5.5",
        "github-copilot/gpt-5.5",
        "anthropic/claude-opus-4-6",
        "huggingface/moonshotai/Kimi-K2.6:novita"
      ]
    }
  }
}
